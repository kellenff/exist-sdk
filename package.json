{
  "name": "@fromo/exist-sdk",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "generate-types": "yarn tsx scripts/generate-types.ts",
    "typecheck": "yarn tsc --noEmit",
    "test": "yarn vitest",
    "test:run": "yarn vitest run",
    "prepare": "husky",
    "lint": "yarn oxlint",
    "format:check": "yarn oxfmt --check",
    "fix": "yarn oxfmt && yarn oxlint --fix",
    "precommit": "yarn lint && yarn format:check",
    "release": "semantic-release"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "oauth4webapi": "^3.8.5",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
